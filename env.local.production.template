# Configuration pour la production (copier vers .env à la racine pour Docker Compose)
# MySQL sur le serveur : depuis les conteneurs, utiliser host.docker.internal
DATABASE_URL="mysql://USER:PASSWORD@host.docker.internal:3306/fonaredd_db"

# Cles secretes pour JWT et NextAuth
# IMPORTANT: Changez ces cles en production pour plus de securite
JWT_SECRET="your-super-secret-jwt-key-change-in-production-very-long-and-secure"
NEXTAUTH_SECRET="your-nextauth-secret-change-in-production"

# Configuration Next.js pour la production
NEXTAUTH_URL="https://fonaredd.com"
NODE_ENV="production"

# Port publié sur l'hôte (voir FONAREDD_APP_PROD_PORT dans .env à la racine pour Docker)
PORT=13001

# SMTP (OTP mot de passe oublié) — ex. Zoho : smtpproto.zoho.com, 587 (TLS) ou 465 (SSL)
EMAIL_SERVER_HOST="smtpproto.zoho.com"
EMAIL_SERVER_PORT=587
# Pour le port 465, mettre EMAIL_SERVER_SECURE=true
# EMAIL_SERVER_SECURE=true
EMAIL_SERVER_USER="votre-email@votredomaine.com"
EMAIL_SERVER_PASSWORD="mot-de-passe-application"
# Même adresse que EMAIL_SERVER_USER si le fournisseur refuse un autre From (ex. Zoho 553)
EMAIL_FROM="votre-email@votredomaine.com"
# Secret dédié aux OTP (sinon repli sur JWT_SECRET)
# PASSWORD_RESET_OTP_SECRET="long-random-string"

# URL publique du site (logo /logo.png dans les e-mails si public/logo.png absent sur le disque du conteneur)
# EMAIL_PUBLIC_BASE_URL="https://fonaredd.com"

# Désactiver l’e-mail « nouvelle connexion » (tests / bruit)
# DISABLE_LOGIN_ALERT_EMAIL=1

