# Reverse proxy vers Next.js (production). TLS géré par Cloudflare (tunnel ou edge).
# Le tunnel pointe vers : http://127.0.0.1:<port hôte mappé sur :80> (ex. 18080).
{
	admin off
}

:80 {
	reverse_proxy app-prod:3000 {
		header_up X-Forwarded-Proto "https"
		header_up X-Forwarded-Host {host}
		header_up Host {host}
	}
}
