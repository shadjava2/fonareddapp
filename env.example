# Ports publiés sur l’hôte (conflits avec d’autres apps)
FONAREDD_APP_DEV_PORT=13000
FONAREDD_APP_PROD_PORT=13001
FONAREDD_REDIS_PORT=16379
FONAREDD_CADDY_HTTP=18080

# MySQL installé sur le serveur (pas dans Docker). Depuis les conteneurs app :
# utilisez host.docker.internal (mappé via host-gateway dans docker-compose).
# Exemple si MySQL écoute sur le port 3306 de l’hôte :
DATABASE_URL="mysql://username:password@host.docker.internal:3306/fonaredd_db"

JWT_SECRET="votre_cle_secrete_jwt_tres_longue_et_complexe"

# URL publique (production derrière Cloudflare)
NEXTAUTH_URL="https://fonaredd.com"
NEXTAUTH_SECRET="votre_cle_secrete_nextauth"

NODE_ENV="development"
