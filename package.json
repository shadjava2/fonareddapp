{
  "name": "fonaredd-app",
  "version": "1.0.0",
  "description": "Application de gestion Fonaredd avec Electron + Next.js PWA",
  "main": "electron/main.js",
  "homepage": "./",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "dev:electron": "concurrently -k -r \"next dev -p 3001\" \"wait-on http://localhost:3001 && cross-env NODE_ENV=development electron .\"",
    "build": "next build",
    "build:prod": "next build",
    "build:electron": "next build && tsc -p electron/tsconfig.json",
    "start": "next start -p 3001",
    "dist": "npm run build && electron-builder",
    "dist:dir": "npm run build && electron-builder --dir",
    "prisma:pull": "prisma db pull",
    "prisma:gen": "prisma generate",
    "prisma:studio": "prisma studio",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "scheduler:monthly": "node scripts/scheduler-monthly-update.js"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.17",
    "@heroicons/react": "^2.0.18",
    "@prisma/client": "^5.7.1",
    "@react-pdf/renderer": "^4.3.1",
    "@types/cookie": "^0.6.0",
    "@types/nodemailer": "^7.0.3",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.0.0",
    "cookie": "^1.0.2",
    "date-fns": "^3.0.6",
    "digest-fetch": "^3.1.1",
    "electron": "^27.1.3",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.6.5",
    "next": "^14.0.4",
    "next-pwa": "^5.6.0",
    "nodemailer": "^7.0.10",
    "prisma": "^5.7.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.2.0",
    "xml2js": "^0.6.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron-builder": "^24.8.1",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.0.4",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.fonaredd.app",
    "productName": "Fonaredd App",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "out/**/*",
      "electron/main.js",
      "electron/preload.js",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.business"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
